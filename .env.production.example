# docker-compose.prod.yml 中 PostgreSQL 必需。
POSTGRES_DB=zeta
POSTGRES_USER=zeta
POSTGRES_PASSWORD=change-me

# API 容器和 Prisma 必需。
DATABASE_URL=postgresql://zeta:change-me@postgres:5432/zeta?schema=public

# JWT 签名必需。生产环境请替换为足够长的随机密钥。
AUTH_TOKEN_SECRET=change-me-to-a-long-random-secret

# 生产 seed 命令必需。
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=123456

# 可选。seed 会用它创建默认 DashScope 模型配置。
DASHSCOPE_API_KEY=
