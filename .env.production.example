# docker-compose.prod.yml 中 PostgreSQL 必需。
POSTGRES_DB=zeta
POSTGRES_USER=zeta
POSTGRES_PASSWORD=change-me

# API 容器和 Prisma 必需。
DATABASE_URL=postgresql://zeta:change-me@postgres:5432/zeta?schema=public

# API 容器连接异步队列和 OCR 服务。
REDIS_HOST=redis
REDIS_PORT=6379
OCR_SERVICE_URL=http://ocr:8001
OCR_LANG=ch
OCR_VERSION=PP-OCRv4
OCR_DETECTION_MODEL=PP-OCRv4_mobile_det
OCR_RECOGNITION_MODEL=PP-OCRv4_mobile_rec
OCR_MAX_PAGES=50
OCR_REQUEST_TIMEOUT_MS=600000

# JWT 签名必需。生产环境请替换为足够长的随机密钥。
AUTH_TOKEN_SECRET=change-me-to-a-long-random-secret

# 生产 seed 命令必需。
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=123456

# 可选。seed 会用它创建默认 DashScope 模型配置。
DASHSCOPE_API_KEY=
