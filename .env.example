# Local PostgreSQL from docker-compose.infra.yml
POSTGRES_DB=zeta
POSTGRES_USER=zeta
POSTGRES_PORT=5432

DATABASE_URL="postgresql://zeta@localhost:5432/zeta?schema=public"

AUTH_TOKEN_SECRET="change-me-for-local-development"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="123456"
SEED_ADMIN_DISPLAY_NAME="Zeta Admin"

DASHSCOPE_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""

# RAG evaluation uses the same root .env as the rest of the project.
ZETA_API_BASE_URL="http://localhost:3000"
ZETA_USERNAME="admin"
ZETA_PASSWORD="123456"

# Ragas evaluation resolves the default resources by name after running
# `pnpm import:markdown-corpus`.
ZETA_EVAL_KNOWLEDGE_BASE_NAME="GitLab Handbook"
ZETA_EVAL_AGENT_NAME="GitLab Handbook Expert"
ZETA_EVAL_TOP_K=5
ZETA_EVAL_REPORT_DIR="evals/reports"
