# Prisma 和 NestJS API 必需。
# 本地基础设施默认数据库名为 `zeta`，用户名为 `zeta`，宿主机端口为 `5432`。
# 只有覆盖 docker-compose.infra.yml 默认值时，才需要额外配置
# POSTGRES_DB / POSTGRES_USER / POSTGRES_PORT。
DATABASE_URL="postgresql://zeta@localhost:5432/zeta?schema=public"

# JWT 签名必需。非本地开发环境请改成更强的随机值。
AUTH_TOKEN_SECRET="change-me-for-local-development"

# 模型供应商 Key。
# DashScope 用于 seed 默认模型、语料导入和 Ragas Embedding。
DASHSCOPE_API_KEY=""

# DeepSeek 是默认的 Ragas LLM-as-a-Judge 供应商。
DEEPSEEK_API_KEY=""

# RAG 评测和项目其他部分共用根目录 .env。
# API 地址、Agent 名称、topK、判官模型和报告目录都有代码默认值；
# 只有自定义评测运行时才需要额外配置。
ZETA_USERNAME="admin"
ZETA_PASSWORD="123456"
